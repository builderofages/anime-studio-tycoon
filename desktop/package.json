{
  "name": "anime-studio-tycoon-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Anime Studio Tycoon — Steam / desktop build (Electron)",
  "author": "TrainYourAgent",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "steamworks.js": "^0.4.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.trainyouragent.animestudiotycoon",
    "productName": "Anime Studio Tycoon",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "steam.js", "achievements.json", "package.json"],
    "extraResources": [
      { "from": "../index.html", "to": "game/index.html" },
      { "from": "../strings.js",  "to": "game/strings.js" },
      { "from": "../logic.js",    "to": "game/logic.js" },
      { "from": "../privacy.html","to": "game/privacy.html" },
      { "from": "../terms.html",  "to": "game/terms.html" }
    ],
    "win": { "target": ["nsis", "zip"] },
    "mac": { "target": ["dmg", "zip"], "category": "public.app-category.games" },
    "linux": { "target": ["AppImage", "tar.gz"], "category": "Game" }
  }
}
