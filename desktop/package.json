{
  "name": "anime-studio-tycoon-desktop",
  "version": "7.0.0",
  "private": true,
  "description": "Anime Studio Tycoon — Steam / desktop build (Electron)",
  "author": "TrainYourAgent",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "steamworks.js": "^0.4.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.trainyouragent.animestudiotycoon",
    "productName": "Anime Studio Tycoon",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "steam.js", "achievements.json", "package.json"],
    "extraResources": [
      {
        "from": "..",
        "to": "game",
        "filter": [
          "index.html",
          "strings.js",
          "logic.js",
          "aaa-upgrade.js",
          "aaa-upgrade.css",
          "gameplay-plus.js",
          "gameplay-plus.css",
          "gameplay-ultra.js",
          "gameplay-ultra.css",
          "gameplay-endless.js",
          "gameplay-endless.css",
          "gameplay-empire.js",
          "gameplay-empire.css",
          "gameplay-studio.js",
          "gameplay-studio.css",
          "manifest.json",
          "privacy.html",
          "terms.html"
        ]
      }
    ],
    "win": { "target": ["nsis", "zip"] },
    "mac": { "target": ["dmg", "zip"], "category": "public.app-category.games" },
    "linux": { "target": ["AppImage", "tar.gz"], "category": "Game" }
  }
}
